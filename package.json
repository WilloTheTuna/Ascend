{
  "name": "ascend",
  "version": "1.0.58",
  "description": "Ascend - EAC-Compatible Rocket League Mod Manager",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder && node scripts/copy-setup.js && node scripts/publish-release.js"
  },
  "author": "Willo",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "adm-zip": "^0.5.14",
    "chokidar": "^3.6.0",
    "ini": "^4.1.3",
    "node-fetch": "^2.7.0",
    "uuid": "^10.0.0",
    "ws": "^8.21.0"
  },
  "build": {
    "appId": "com.ascend.app",
    "productName": "Ascend",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "include": "build/installer.nsh",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "asarUnpack": [
      "src/python/**"
    ],
    "publish": null
  }
}
